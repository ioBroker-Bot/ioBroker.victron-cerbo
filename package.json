{
  "name": "iobroker.victron-cerbo",
  "description": "ioBroker adapter for Victron Cerbo GX devices via MQTT",
  "version": "0.1.0",
  "author": "Denis Haev <dogafox@gmail.com>",
  "homepage": "https://github.com/ioBroker/ioBroker.victron-cerbo",
  "repository": {
    "type": "git",
    "url": "https://github.com/ioBroker/ioBroker.victron-cerbo"
  },
  "keywords": [
    "ioBroker",
    "victron",
    "cerbo",
    "MQTT",
    "energy",
    "solar"
  ],
  "dependencies": {
    "@iobroker/adapter-core": "^3.3.2",
    "bonjour-service": "^1.3.0",
    "mqtt": "^5.15.1"
  },
  "devDependencies": {
    "@alcalzone/release-script": "^5.1.1",
    "@alcalzone/release-script-plugin-iobroker": "^5.1.2",
    "@alcalzone/release-script-plugin-license": "^5.1.1",
    "@iobroker/eslint-config": "^2.2.0",
    "@iobroker/testing": "^5.2.2",
    "@iobroker/types": "^7.1.1",
    "aedes": "^1.0.2",
    "typescript": "~5.9.3"
  },
  "bugs": {
    "url": "https://github.com/ioBroker/ioBroker.victron-cerbo/issues"
  },
  "main": "build/main.js",
  "files": [
    "admin/",
    "build/",
    "io-package.json",
    "LICENSE"
  ],
  "scripts": {
    "test:integration": "mocha test/integration.js --exit",
    "test:package": "mocha test/testPackageFiles.js --exit",
    "test": "npm run test:integration",
    "lint": "eslint -c eslint.config.mjs",
    "build": "tsc -p tsconfig.build.json",
    "release": "release-script",
    "release-patch": "release-script patch --yes",
    "release-minor": "release-script minor --yes",
    "release-major": "release-script major --yes",
    "update-packages": "npx -y npm-check-updates --upgrade"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT"
}
