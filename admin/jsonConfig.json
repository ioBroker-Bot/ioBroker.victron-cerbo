{
    "type": "panel",
    "i18n": true,
    "items": {
        "_header1": {
            "type": "header",
            "text": "Connection settings",
            "size": 3,
            "xs": 12,
            "sm": 12,
            "md": 12,
            "lg": 12,
            "xl": 12
        },
        "_discover": {
            "newLine": true,
            "type": "sendTo",
            "label": "Discover Cerbo GX devices",
            "icon": "search",
            "command": "discover",
            "jsonData": "{\"timeout\": 5000}",
            "variant": "outlined",
            "xs": 12,
            "sm": 12,
            "md": 12,
            "lg": 12,
            "xl": 12,
            "hidden": "!!data.mqttHost"
        },
        "_discoveryResult": {
            "type": "selectSendTo",
            "label": "Discovered devices",
            "command": "discover",
            "jsonData": "{\"timeout\": 5000}",
            "manual": false,
            "alsoDependsOn": ["mqttHost", "portalId"],
            "xs": 12,
            "sm": 12,
            "md": 12,
            "lg": 12,
            "xl": 12,
            "hidden": "!!data.mqttHost"
        },
        "mqttHost": {
            "newLine": true,
            "type": "text",
            "label": "MQTT broker host",
            "help": "IP address or hostname of the Victron Cerbo GX",
            "xs": 12,
            "sm": 12,
            "md": 6,
            "lg": 4,
            "xl": 4
        },
        "mqttPort": {
            "label": "MQTT broker port",
            "type": "number",
            "min": 1,
            "max": 65535,
            "xs": 12,
            "sm": 12,
            "md": 6,
            "lg": 4,
            "xl": 4
        },
        "portalId": {
            "label": "VRM Portal ID",
            "type": "text",
            "help": "VRM Portal ID of the Cerbo GX (e.g. c0619ab82b23). Found in Settings > VRM online portal. Leave empty for auto-detection",
            "xs": 12,
            "sm": 12,
            "md": 6,
            "lg": 4,
            "xl": 4
        },
        "_header2": {
            "newLine": true,
            "type": "header",
            "text": "Authentication settings",
            "size": 3,
            "xs": 12,
            "sm": 12,
            "md": 12,
            "lg": 12,
            "xl": 12
        },
        "user": {
            "newLine": true,
            "type": "text",
            "label": "User",
            "xs": 12,
            "sm": 12,
            "md": 6,
            "lg": 4,
            "xl": 4
        },
        "password": {
            "xs": 12,
            "sm": 12,
            "md": 6,
            "lg": 4,
            "xl": 4,
            "type": "password",
            "label": "Password",
            "repeat": true
        },
        "_header3": {
            "newLine": true,
            "type": "header",
            "text": "Advanced settings",
            "size": 3,
            "xs": 12,
            "sm": 12,
            "md": 12,
            "lg": 12,
            "xl": 12
        },
        "keepaliveInterval": {
            "newLine": true,
            "type": "number",
            "label": "Keepalive interval",
            "help": "Interval in seconds for sending keepalive to Cerbo GX",
            "min": 5,
            "max": 55,
            "xs": 12,
            "sm": 12,
            "md": 6,
            "lg": 4,
            "xl": 4
        },
        "mqttClientId": {
            "type": "text",
            "label": "MQTT Client ID",
            "help": "Custom MQTT client ID (leave empty for auto-generated)",
            "xs": 12,
            "sm": 12,
            "md": 6,
            "lg": 4,
            "xl": 4
        }
    }
}
