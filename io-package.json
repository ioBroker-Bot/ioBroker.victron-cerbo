      "energy",
      "solar"
    ],
    "connectionType": "local",
    "dataSource": "push",
    "tier": 2,
    "extIcon": "https://raw.githubusercontent.com/ioBroker/ioBroker.victron-cerbo/master/admin/victron-cerbo.svg",
    "type": "energy",
    "dependencies": [
      {
        "js-controller": ">=5.0.19"
      }
    ],
    "globalDependencies": [
      {
        "admin": ">=7.6.17"
      }
    ]
  },
  "encryptedNative": [
    "password"
  ],
  "protectedNative": [
    "password"
  ],
  "native": {
    "port": 1883,
    "bind": "0.0.0.0",
    "user": "",
    "password": "",
    "timeout": 300,
    "TELE_SENSOR": true,
    "TELE_MARGINS": false,
    "TELE_STATE": true,
    "STAT_RESULT": false,
    "OBJ_TREE": false,
    "storeClientsTime": 1440,
    "defaultQoS": 0,
    "retransmitInterval": 2000,
    "retransmitCount": 10,
    "ignorePings": false,
    "ignoreNotConnectedWarnings": false
  },
  "objects": [],
  "instanceObjects": [
    {
      "_id": "info",
      "type": "channel",
      "common": {
        "name": "Information"
      },
      "native": {}
    },
    {
      "_id": "info.connection",
      "type": "state",
      "common": {
        "role": "info.clients",
        "name": "List of connected clients",
        "type": "string",
        "read": true,
        "write": false
      },
      "native": {}
    }
  ]
